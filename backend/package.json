{
  "name": "doctraceai-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Express backend for the DocTraceAI document intelligence platform.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "worker": "node src/worker.js",
    "migrate": "node scripts/migrate.js",
    "test": "node --test --test-concurrency=1",
    "check": "node --check src/server.js && node --check src/worker.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.50.0",
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.9.1",
    "multer": "^2.0.1",
    "nodemailer": "^8.0.11",
    "pdfjs-dist": "^5.3.31",
    "pg": "^8.16.0",
    "pino": "^9.7.0",
    "prom-client": "^15.1.3",
    "yauzl": "^3.2.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "docx": "^9.7.1",
    "jszip": "^3.10.1",
    "pdf-lib": "^1.17.1",
    "supertest": "^7.1.1"
  }
}
