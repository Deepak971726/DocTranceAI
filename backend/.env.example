APP_NAME=DocTraceAI API
APP_ENV=development
APP_DEBUG=false
API_V1_PREFIX=/api/v1
PORT=8000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
TRUSTED_HOSTS=["localhost","127.0.0.1"]

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/doctraceai
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_SSL_REQUIRE=true

JWT_SECRET_KEY=development-only-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
PASSWORD_RESET_EXPIRE_MINUTES=30

SUPABASE_URL=https://example.supabase.co
SUPABASE_SERVICE_ROLE_KEY=development-placeholder
SUPABASE_STORAGE_BUCKET=documents

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=document_chunks

EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3:latest
OLLAMA_REQUEST_TIMEOUT_SECONDS=1200
OLLAMA_KEEP_ALIVE=30m
OLLAMA_CONTEXT_TOKENS=2048

MAX_UPLOAD_BYTES=26214400
CHUNK_SIZE=800
CHUNK_OVERLAP=150
RAG_TOP_K=6
RAG_SCORE_THRESHOLD=0.35
WORKER_POLL_SECONDS=5
WORKER_STALE_MINUTES=20
WORKER_MAX_RETRIES=3

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.com
SMTP_USE_TLS=true

LOG_LEVEL=info
LOG_JSON=false
